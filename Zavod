-- ============================================
-- STRESS CONTROL v1.2
-- Standalone program for toggling farms via inverted redstone relays.
-- Relay HIGH = farm OFF (powered = stops the contraption)
-- Relay LOW  = farm ON  (no signal = farm runs)
-- ============================================

-- ============================================ STATE ============================================

local config = {
    controlMonitor = nil,    -- main UI: farm list + settings
    stressMonitor  = nil,    -- big stress display
    animMonitor    = nil,    -- now: vaults fill-level display
    farms          = {},     -- {id, name, relay, relaySide, enabled}
    vaults         = {},     -- {id, name, peripheral}
}

local screen = "main"  -- main, settings, add_name, add_relay, add_side, pick_monitor, vaults, add_vault_name, add_vault_peri
local addBuf = ""
local addDraft = nil
local prevHash = nil
local layoutCache = nil
local pickerTarget = nil  -- "control" | "stress" | "anim"
local addKind = nil       -- "farm" | "vault" - which wizard the keyboard is for

-- Stressometer (Create mod)
local stressData = nil  -- {current, capacity, name} or nil

-- Vault data: id -> {pct, slotsUsed, slotsTotal, valid, name}
local vaultData = {}

local function readStress()
    local stressTypes = { "Create_Stressometer", "create:stressometer", "stressometer" }
    for _, n in ipairs(peripheral.getNames()) do
        local t = peripheral.getType(n)
        for _, st in ipairs(stressTypes) do
            if t == st then
                local p = peripheral.wrap(n)
                if p then
                    local okC, cur = pcall(p.getStress)
                    local okM, max = pcall(p.getStressCapacity)
                    if okC and okM
                       and type(cur) == "number" and type(max) == "number"
                       and max > 0 then
                        stressData = { current = cur, capacity = max, name = n }
                        return true
                    end
                end
            end
        end
    end
    stressData = nil
    return false
end

-- ============================================ UTILS ============================================

local function genId()
    local i = 1
    while true do
        local exists = false
        for _, f in ipairs(config.farms) do
            if f.id == "farm_" .. i then exists = true; break end
        end
        if not exists then return "farm_" .. i end
        i = i + 1
    end
end

local function findFarm(id)
    for _, f in ipairs(config.farms) do
        if f.id == id then return f end
    end
end

local function listByType(t)
    local r = {}
    for _, n in ipairs(peripheral.getNames()) do
        if peripheral.getType(n) == t then table.insert(r, n) end
    end
    table.sort(r); return r
end

local SIDES = { "top", "bottom", "left", "right", "front", "back" }

-- ============================================ VAULTS ============================================

local function genVaultId()
    local i = 1
    while true do
        local exists = false
        for _, v in ipairs(config.vaults) do
            if v.id == "vault_" .. i then exists = true; break end
        end
        if not exists then return "vault_" .. i end
        i = i + 1
    end
end

-- Lists peripherals that look like inventories. We avoid peripheral.wrap()
-- on every device (slow on large Create vaults) and instead filter by type.
local function listInventoryPeripherals()
    local r = {}
    for _, n in ipairs(peripheral.getNames()) do
        local t = peripheral.getType(n) or ""
        -- Anything that's not a relay/modem/monitor/computer is likely an inventory
        if t ~= "redstone_relay"
           and t ~= "modem"
           and t ~= "monitor"
           and t ~= "computer"
           and t ~= "speaker"
           and t ~= "drive"
           and t ~= "printer"
           and not t:find("stressometer", 1, true)
           and not t:find("speedometer", 1, true) then
            table.insert(r, n)
        end
    end
    table.sort(r)
    return r
end

local function readOneVault(v)
    local p = peripheral.wrap(v.peripheral)
    if not p or type(p.list) ~= "function" or type(p.size) ~= "function" then
        return { valid = false, pct = 0, slotsUsed = 0, slotsTotal = 0, name = v.name }
    end
    local okS, size = pcall(p.size)
    if not okS or type(size) ~= "number" or size <= 0 then
        return { valid = false, pct = 0, slotsUsed = 0, slotsTotal = 0, name = v.name }
    end
    local okL, items = pcall(p.list)
    if not okL or type(items) ~= "table" then
        return { valid = false, pct = 0, slotsUsed = 0, slotsTotal = size, name = v.name }
    end

    -- Fast approximation: sum item.count, assume max stack 64 per slot.
    -- Calling getItemLimit per slot is SLOW (blocks main thread for 100+ ms
    -- on large Create vaults), so we don't do it here.
    local totalCount = 0
    local used = 0
    for _, item in pairs(items) do
        used = used + 1
        if type(item) == "table" and type(item.count) == "number" then
            totalCount = totalCount + item.count
        end
    end

    local maxPossible = size * 64
    local pct = 0
    if maxPossible > 0 then
        pct = totalCount / maxPossible * 100
    end
    if pct < 0 then pct = 0 end
    if pct > 100 then pct = 100 end

    return {
        valid = true,
        pct = pct,
        slotsUsed = used,
        slotsTotal = size,
        name = v.name,
    }
end

local function readAllVaults()
    local newData = {}
    for _, v in ipairs(config.vaults) do
        newData[v.id] = readOneVault(v)
    end
    vaultData = newData
end

local function saveConfig()
    local ok, txt = pcall(textutils.serialize, config)
    if not ok then return end
    local f = fs.open("farms.dat", "w")
    if f then f.write(txt); f.close() end
end

local function loadConfig()
    if not fs.exists("farms.dat") then return false end
    local f = fs.open("farms.dat", "r"); if not f then return false end
    local txt = f.readAll(); f.close()
    local ok, decoded = pcall(textutils.unserialize, txt)
    if not ok or type(decoded) ~= "table" then return false end
    config.controlMonitor = decoded.controlMonitor or decoded.monitor
    config.stressMonitor  = decoded.stressMonitor
    config.animMonitor    = decoded.animMonitor
    config.farms          = decoded.farms or {}
    config.vaults         = decoded.vaults or {}
    return true
end

-- ============================================ RELAY CONTROL ============================================

local function applyFarm(farm)
    if not farm.relay or farm.relay == "" then return end
    local r = peripheral.wrap(farm.relay)
    if not r or not r.setOutput then return end
    -- Inverted: enabled=true means signal LOW, disabled=true means signal HIGH
    pcall(r.setOutput, farm.relaySide or "top", not farm.enabled)
end

local function applyAllFarms()
    for _, f in ipairs(config.farms) do applyFarm(f) end
end

local function setFarmEnabled(id, on)
    local f = findFarm(id); if not f then return end
    f.enabled = on
    applyFarm(f)
    saveConfig()
end

local function toggleFarm(id)
    local f = findFarm(id); if not f then return end
    setFarmEnabled(id, not f.enabled)
end

-- ============================================ MONITOR HELPERS ============================================

-- ============================================ BUFFERED DRAW ============================================
-- Eliminates flicker by drawing to an invisible window, then making it visible
-- once the frame is complete. Falls back to direct draw if window API unsupported.

local monWindows = {}  -- monitor name -> {win}

local function getBuffer(mon, monName)
    if not monName then return mon end
    local w, h = mon.getSize()
    local cached = monWindows[monName]
    if cached and cached.win then
        local cw, ch = cached.win.getSize()
        if cw == w and ch == h then return cached.win end
    end
    local ok, win = pcall(window.create, mon, 1, 1, w, h, false)
    if not ok or not win then
        monWindows[monName] = nil
        return mon
    end
    monWindows[monName] = { win = win }
    return win
end

local function flushBuffer(monNameOrWin)
    local cached
    if type(monNameOrWin) == "string" then
        cached = monWindows[monNameOrWin]
    else
        for _, entry in pairs(monWindows) do
            if entry.win == monNameOrWin then cached = entry; break end
        end
    end
    if cached and cached.win then
        cached.win.setVisible(true)
        cached.win.setVisible(false)
    end
end

local function flushAllMonitors()
    for _, entry in pairs(monWindows) do
        if entry.win then
            entry.win.setVisible(true)
            entry.win.setVisible(false)
        end
    end
end

local function getControlMon()
    if not config.controlMonitor then return nil end
    local m = peripheral.wrap(config.controlMonitor)
    if not m then return nil end
    return getBuffer(m, config.controlMonitor)
end
local function getStressMon()
    if not config.stressMonitor then return nil end
    local m = peripheral.wrap(config.stressMonitor)
    if not m then return nil end
    return getBuffer(m, config.stressMonitor)
end
local function getAnimMon()
    if not config.animMonitor then return nil end
    local m = peripheral.wrap(config.animMonitor)
    if not m then return nil end
    return getBuffer(m, config.animMonitor)
end

-- For autoScale we need the physical monitor (setTextScale isn't on window).
local function getRawMon(name)
    if not name then return nil end
    return peripheral.wrap(name)
end

local function getMon() return getControlMon() end

local function fillRect(mon, x1, y1, x2, y2, bg)
    mon.setBackgroundColor(bg)
    for y = y1, y2 do
        mon.setCursorPos(x1, y)
        mon.write(string.rep(" ", x2 - x1 + 1))
    end
end

-- Find a text scale that gives at least minW x minH characters AND fills
-- as much of the physical screen as possible. We prefer larger text (more
-- readable) over smaller text whenever both fit.
-- autoScale operates on the RAW monitor (setTextScale not on windows),
-- then we resize the buffered window to match the new char size.
-- Caller passes the (possibly windowed) mon; we look up its name.
local function autoScale(monOrName, minW, minH)
    local monName
    if type(monOrName) == "string" then
        monName = monOrName
    else
        -- Find which name this window/monitor corresponds to
        for n, entry in pairs(monWindows) do
            if entry.win == monOrName then monName = n; break end
        end
        -- If we can't find it among windows, this is a raw monitor we're stuck with
        if not monName then
            -- Try to set scale directly on whatever was passed; assume it's a monitor
            if type(monOrName) == "table" and monOrName.setTextScale then
                local SCALES = { 3, 2.5, 2, 1.5, 1, 0.5 }
                for _, s in ipairs(SCALES) do
                    pcall(monOrName.setTextScale, s)
                    local w, h = monOrName.getSize()
                    if w >= minW and h >= minH then return s, w, h end
                end
                pcall(monOrName.setTextScale, 0.5)
                local w, h = monOrName.getSize()
                return 0.5, w, h
            end
            return 1, 0, 0
        end
    end

    local raw = peripheral.wrap(monName)
    if not raw or not raw.setTextScale then return 1, 0, 0 end
    local SCALES = { 3, 2.5, 2, 1.5, 1, 0.5 }
    local best = nil
    for _, s in ipairs(SCALES) do
        pcall(raw.setTextScale, s)
        local w, h = raw.getSize()
        if w >= minW and h >= minH then
            best = { s = s, w = w, h = h }
            break
        end
    end
    if not best then
        pcall(raw.setTextScale, 0.5)
        local w, h = raw.getSize()
        best = { s = 0.5, w = w, h = h }
    end
    -- Resize the buffered window to match
    local cached = monWindows[monName]
    if cached and cached.win then
        local cw, ch = cached.win.getSize()
        if cw ~= best.w or ch ~= best.h then
            pcall(cached.win.reposition, 1, 1, best.w, best.h)
        end
    end
    return best.s, best.w, best.h
end

local function drawHeader(mon, w, title, color)
    color = color or colors.gray
    mon.setBackgroundColor(color); mon.setTextColor(colors.white)
    for x = 1, w do mon.setCursorPos(x, 1); mon.write(" ") end
    local t = title
    if #t > w - 2 then t = t:sub(1, w - 2) end
    mon.setCursorPos(math.floor((w - #t) / 2) + 1, 1); mon.write(t)
    mon.setBackgroundColor(colors.black)
end

local function drawBtn(mon, x1, y1, x2, y2, text, bg, fg, action)
    fillRect(mon, x1, y1, x2, y2, bg)
    local cx = x1 + math.floor(((x2 - x1 + 1) - #text) / 2)
    local cy = y1 + math.floor((y2 - y1) / 2)
    mon.setCursorPos(cx, cy); mon.setTextColor(fg)
    mon.write(text)
    mon.setBackgroundColor(colors.black)
    if action and layoutCache then
        layoutCache[action] = { x1 = x1, y1 = y1, x2 = x2, y2 = y2 }
    end
end

local function centerText(mon, w, y, text, color)
    if color then mon.setTextColor(color) end
    mon.setCursorPos(math.floor((w - #text) / 2) + 1, y)
    mon.write(text)
end

-- ============================================ MAIN SCREEN ============================================

local function drawMain(force)
    local mon = getMon(); if not mon then return end
    layoutCache = {}
    local _, w, h = autoScale(mon, 16, 8)
    mon.setBackgroundColor(colors.black); mon.clear()

    drawHeader(mon, w, "STRESS CONTROL", colors.cyan)

    local listTop = 3
    local listBottom = h - 2

    if #config.farms == 0 then
        mon.setTextColor(colors.gray)
        centerText(mon, w, math.floor((listTop + listBottom) / 2), "No farms yet", colors.gray)
        centerText(mon, w, math.floor((listTop + listBottom) / 2) + 1, "Tap [SETTINGS]", colors.gray)
    else
        local nFarms = #config.farms
        local available = listBottom - listTop + 1
        local rowH = math.min(3, math.max(1, math.floor(available / nFarms)))
        if rowH > 1 and nFarms * rowH > available then rowH = 1 end

        local btnW = math.min(8, math.floor(w / 4))
        if btnW < 5 then btnW = 5 end

        for i, f in ipairs(config.farms) do
            local rowTop = listTop + (i - 1) * rowH
            local rowBot = rowTop + rowH - 1
            if rowBot > listBottom then break end

            local nameY = rowTop + math.floor((rowH - 1) / 2)
            local nm = f.name
            local maxNameLen = w - btnW - 4
            if #nm > maxNameLen then nm = nm:sub(1, maxNameLen - 1) .. "." end
            mon.setBackgroundColor(colors.black); mon.setTextColor(colors.white)
            mon.setCursorPos(2, nameY); mon.write(nm)

            local btnX2 = w - 1
            local btnX1 = btnX2 - btnW + 1
            local label = f.enabled and "ON" or "OFF"
            local bg = f.enabled and colors.lime or colors.gray
            local fg = f.enabled and colors.black or colors.white
            drawBtn(mon, btnX1, rowTop, btnX2, rowBot, label, bg, fg, "toggle_" .. f.id)
        end
    end

    drawBtn(mon, 2, h - 1, w - 1, h, "[ SETTINGS ]", colors.gray, colors.white, "go_settings")
end

-- ============================================ STRESS MONITOR ============================================

local function drawStressMonitor()
    local mon = getStressMon(); if not mon then return end
    local _, w, h = autoScale(mon, 16, 8)
    mon.setBackgroundColor(colors.black); mon.clear()

    -- Title bar
    mon.setBackgroundColor(colors.purple); mon.setTextColor(colors.white)
    for x = 1, w do mon.setCursorPos(x, 1); mon.write(" ") end
    local title = "STRESS"
    mon.setCursorPos(math.floor((w - #title) / 2) + 1, 1); mon.write(title)
    mon.setBackgroundColor(colors.black)

    if not stressData or stressData.capacity <= 0 then
        mon.setTextColor(colors.gray)
        local msg1 = "No stressometer"
        local msg2 = "or network idle"
        mon.setCursorPos(math.floor((w - #msg1) / 2) + 1, math.floor(h / 2))
        mon.write(msg1)
        mon.setCursorPos(math.floor((w - #msg2) / 2) + 1, math.floor(h / 2) + 1)
        mon.write(msg2)
        return
    end

    local cur = stressData.current
    local cap = stressData.capacity
    local pct = cur / cap * 100
    if pct > 100 then pct = 100 end
    if pct < 0 then pct = 0 end

    local color = colors.lime
    if pct >= 100 then color = colors.red
    elseif pct >= 90 then color = colors.orange
    elseif pct >= 70 then color = colors.yellow
    end

    -- Big percentage in the center
    local pctStr = string.format("%d%%", math.floor(pct + 0.5))
    mon.setTextColor(color)
    local pctY = math.max(3, math.floor(h / 2) - 1)
    mon.setCursorPos(math.floor((w - #pctStr) / 2) + 1, pctY)
    mon.write(pctStr)

    -- Numeric values below
    local numStr = string.format("%d / %d SU", math.floor(cur), math.floor(cap))
    if #numStr > w - 2 then
        numStr = string.format("%d/%d", math.floor(cur), math.floor(cap))
    end
    mon.setTextColor(colors.lightGray)
    mon.setCursorPos(math.floor((w - #numStr) / 2) + 1, pctY + 1)
    mon.write(numStr)

    -- Big bar at the bottom (4 rows tall if room)
    local barTop = h - 4
    local barBot = h - 1
    if barTop < pctY + 3 then barTop = pctY + 3 end
    if barBot < barTop then barBot = barTop end

    local barX1, barX2 = 2, w - 1
    local barW = barX2 - barX1 + 1
    local filled = math.floor(barW * pct / 100 + 0.5)
    if filled < 0 then filled = 0 end
    if filled > barW then filled = barW end

    for y = barTop, barBot do
        mon.setCursorPos(barX1, y)
        mon.setBackgroundColor(color)
        mon.write(string.rep(" ", filled))
        mon.setBackgroundColor(colors.gray)
        mon.write(string.rep(" ", barW - filled))
    end
    mon.setBackgroundColor(colors.black)

    -- Status label under the bar (or above if no room)
    if h >= 12 then
        local label = (pct >= 100) and "OVERSTRESSED" or
                      (pct >= 90)  and "CRITICAL"     or
                      (pct >= 70)  and "HIGH"         or
                      (pct >= 30)  and "OK"           or "IDLE"
        mon.setTextColor(color)
        mon.setCursorPos(math.floor((w - #label) / 2) + 1, h)
        mon.write(label)
    end
end

-- ============================================ VAULTS MONITOR ============================================
-- Renders each vault as a fill-level box with name underneath and % inside.
-- Grid auto-fits to monitor size.

local function vaultColor(pct)
    if pct >= 99   then return colors.red end
    if pct >= 85   then return colors.orange end
    if pct >= 60   then return colors.yellow end
    if pct >  0    then return colors.lime end
    return colors.gray
end

local function drawVaultsMonitor()
    local mon = getAnimMon(); if not mon then return end
    local _, w, h = autoScale(mon, 16, 10)
    mon.setBackgroundColor(colors.black); mon.clear()

    -- Title
    mon.setBackgroundColor(colors.cyan); mon.setTextColor(colors.black)
    for x = 1, w do mon.setCursorPos(x, 1); mon.write(" ") end
    local title = "VAULTS"
    mon.setCursorPos(math.floor((w - #title) / 2) + 1, 1); mon.write(title)
    mon.setBackgroundColor(colors.black)

    local list = vaultData
    -- Build ordered list using config.vaults to keep stable order
    local ordered = {}
    for _, v in ipairs(config.vaults) do
        if list[v.id] then table.insert(ordered, list[v.id]) end
    end

    if #ordered == 0 then
        mon.setTextColor(colors.gray)
        local m1 = "No vaults configured"
        local m2 = "Add via Settings"
        mon.setCursorPos(math.floor((w - #m1) / 2) + 1, math.floor(h / 2));     mon.write(m1)
        mon.setCursorPos(math.floor((w - #m2) / 2) + 1, math.floor(h / 2) + 1); mon.write(m2)
        return
    end

    -- Layout: rows of boxes. Box has body (variable rows) + 1 name row + 1 gap.
    -- Pick a column count that gives readable boxes (min width 6 per box).
    local areaTop, areaBot = 3, h
    local areaH = areaBot - areaTop + 1

    local n = #ordered
    local minBoxW = 6
    local cols = math.min(n, math.max(1, math.floor((w - 1) / (minBoxW + 1))))
    local rows = math.ceil(n / cols)

    local gapX = 1
    local boxW = math.floor((w - 1 - gapX * (cols - 1)) / cols)
    if boxW < minBoxW then boxW = minBoxW end

    local gapY = 1
    local nameRows = 1
    local rowH = math.floor((areaH - gapY * (rows - 1)) / rows)
    local bodyH = rowH - nameRows
    if bodyH < 3 then bodyH = 3; rowH = bodyH + nameRows end

    -- Center the grid horizontally
    local gridW = boxW * cols + gapX * (cols - 1)
    local startX = math.max(1, math.floor((w - gridW) / 2) + 1)

    for i, vd in ipairs(ordered) do
        local rIdx = math.floor((i - 1) / cols)
        local cIdx = (i - 1) % cols
        local boxX1 = startX + cIdx * (boxW + gapX)
        local boxX2 = boxX1 + boxW - 1
        local boxY1 = areaTop + rIdx * (rowH + gapY)
        local boxY2 = boxY1 + bodyH - 1
        if boxY2 > h - 1 then break end

        local color = vaultColor(vd.pct)
        if not vd.valid then color = colors.gray end

        -- Compute fill height (bottom-up)
        local innerH = bodyH
        local pct = vd.pct
        if pct < 0 then pct = 0 end
        if pct > 100 then pct = 100 end
        local fillRows = math.floor(innerH * pct / 100 + 0.5)
        if vd.valid and pct > 0 and fillRows == 0 then fillRows = 1 end

        -- Draw box: empty top portion, filled bottom portion
        local emptyTopRows = innerH - fillRows
        for r = 0, emptyTopRows - 1 do
            mon.setCursorPos(boxX1, boxY1 + r)
            mon.setBackgroundColor(colors.gray)
            mon.write(string.rep(" ", boxW))
        end
        for r = emptyTopRows, innerH - 1 do
            mon.setCursorPos(boxX1, boxY1 + r)
            mon.setBackgroundColor(color)
            mon.write(string.rep(" ", boxW))
        end

        -- Border (thin frame on top + corners with brackets)
        mon.setBackgroundColor(colors.black)
        mon.setTextColor(colors.lightGray)
        -- We don't draw an explicit border so the box looks like a solid pill;
        -- but mark the top edge with darker tick to imply lid
        -- (skip for now to keep clean look)

        -- Percent text centered inside (try to keep readable contrast)
        local pctStr
        if vd.valid then
            pctStr = string.format("%d%%", math.floor(pct + 0.5))
        else
            pctStr = "?"
        end
        local cx = boxX1 + math.floor((boxW - #pctStr) / 2)
        local cy = boxY1 + math.floor(innerH / 2)
        -- Determine bg under text and pick contrasting fg
        local rowFromBottom = boxY1 + innerH - 1 - cy
        local textOverFill = rowFromBottom < fillRows
        local bgUnder = textOverFill and color or colors.gray
        local fgText = colors.black
        -- Yellow/lime/gray are fine with black; red/orange need white for readability
        if bgUnder == colors.red or bgUnder == colors.orange then fgText = colors.white end
        if bgUnder == colors.gray then fgText = colors.white end
        mon.setCursorPos(cx, cy)
        mon.setBackgroundColor(bgUnder)
        mon.setTextColor(fgText)
        mon.write(pctStr)
        mon.setBackgroundColor(colors.black)

        -- Name underneath
        local nameY = boxY2 + 1
        if nameY <= h then
            local nm = vd.name or ""
            if #nm > boxW then nm = nm:sub(1, boxW) end
            local nx = boxX1 + math.floor((boxW - #nm) / 2)
            if not vd.valid then mon.setTextColor(colors.red) else mon.setTextColor(colors.white) end
            mon.setCursorPos(nx, nameY); mon.write(nm)
        end
    end
end

-- ============================================ SETTINGS SCREEN ============================================

local function drawSettings()
    local mon = getMon(); if not mon then return end
    layoutCache = {}
    local _, w, h = autoScale(mon, 22, 12)
    mon.setBackgroundColor(colors.black); mon.clear()

    drawHeader(mon, w, "SETTINGS", colors.purple)

    local function monRow(y, label, value, action)
        mon.setBackgroundColor(colors.black)
        mon.setTextColor(colors.lightGray)
        mon.setCursorPos(2, y); mon.write(label)
        mon.setTextColor(value and colors.white or colors.gray)
        local v = value or "(none)"
        local maxLen = w - 11
        if #v > maxLen then v = v:sub(1, maxLen - 1) .. "." end
        mon.setCursorPos(2, y + 1); mon.write(v)
