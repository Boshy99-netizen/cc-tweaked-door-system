        print("")
        for _, f in ipairs(config.farms) do
            local st = f.enabled and "ON" or "OFF"
            term.setTextColor(f.enabled and colors.lime or colors.gray)
            print(("  [%s] %s (%s/%s)"):format(st, f.name, f.relay, f.relaySide))
        end
    end
    term.setTextColor(colors.gray); print("")
    print("[R] reboot   [W] wipe state")
end

local function consoleLoop()
    showConsoleSummary()
    while true do
        local ev = { os.pullEvent() }
        if ev[1] == "key" then
            local k = ev[2]
            if k == keys.r then os.reboot()
            elseif k == keys.w then
                term.setTextColor(colors.red); print("Type YES to wipe:")
                if read() == "YES" then
                    fs.delete("farms.dat")
                    print("Wiped. Rebooting..."); sleep(1); os.reboot()
                else
                    showConsoleSummary()
                end
            end
        elseif ev[1] == "term_resize" then
            showConsoleSummary()
        end
    end
end

-- Separate coroutine for vault polling so it doesn't block UI touches.
-- Each vault is read with sleep between to yield to the scheduler.
local function vaultPollLoop()
    while true do
        for _, v in ipairs(config.vaults) do
            local ok, data = pcall(readOneVault, v)
            if ok and data then
                vaultData[v.id] = data
            end
            sleep(0)  -- yield between vaults
        end
        -- Redraw monitor + vaults list (if visible). These calls are quick.
        local okD = pcall(drawVaultsMonitor)
        if screen == "vaults" then pcall(drawCurrent) end
        sleep(2)  -- between full polling rounds
    end
end

local function monitorLoop()
    readStress()
    drawCurrent()
    drawStressMonitor()
    drawVaultsMonitor()

    local stressTimer = os.startTimer(1)

    while true do
        local ev = { os.pullEvent() }
        if ev[1] == "monitor_touch" then
            local n, x, y = ev[2], ev[3], ev[4]
            if n == config.controlMonitor then
                local action = findClicked(x, y)
                if action then handleAction(action) end
            end

        elseif ev[1] == "timer" then
            if ev[2] == stressTimer then
                readStress()
                drawStressMonitor()
                stressTimer = os.startTimer(1)
            end

        elseif ev[1] == "peripheral" then
            readStress()
            drawCurrent()
            drawStressMonitor()
            -- vaultPollLoop will refresh vault data on its own cycle

        elseif ev[1] == "peripheral_detach" then
            local n = ev[2]
            if stressData and n == stressData.name then
                stressData = nil
                drawStressMonitor()
            end
            for _, v in ipairs(config.vaults) do
                if v.peripheral == n then
                    vaultData[v.id] = { valid = false, pct = 0, slotsUsed = 0, slotsTotal = 0, name = v.name }
                end
            end
            drawVaultsMonitor()

        elseif ev[1] == "monitor_resize" then
            local n = ev[2]
            if n == config.controlMonitor then drawCurrent()
            elseif n == config.stressMonitor then drawStressMonitor()
            elseif n == config.animMonitor then drawVaultsMonitor() end
        end
    end
end

-- ============================================ STARTUP ============================================

loadConfig()

if not config.controlMonitor or not peripheral.wrap(config.controlMonitor) then
    pickMonitor()
end

-- Apply current state to all relays so reboot doesn't leave farms in random state.
applyAllFarms()

parallel.waitForAny(monitorLoop, consoleLoop, vaultPollLoop)
