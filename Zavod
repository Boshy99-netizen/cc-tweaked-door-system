-- ============================================ DRAW DISPATCH ============================================

local function drawCurrent()
    if screen == "main" then drawMain()
    elseif screen == "settings" then drawSettings()
    elseif screen == "add_name" then drawAddName()
    elseif screen == "add_relay" then drawAddRelay()
    elseif screen == "add_side" then drawAddSide()
    elseif screen == "pick_monitor" then drawPickMonitor()
    end
end

-- ============================================ TOUCH HANDLING ============================================

local function findClicked(x, y)
    if not layoutCache then return nil end
    for action, r in pairs(layoutCache) do
        if x >= r.x1 and x <= r.x2 and y >= r.y1 and y <= r.y2 then return action end
    end
    return nil
end

local function handleAction(action)
    -- Universal cancel
    if action == "cancel" then
        if screen == "pick_monitor" then
            pickerTarget = nil
            screen = "settings"
        else
            addDraft = nil; addBuf = ""
            screen = "settings"
        end
        drawCurrent()
        return
    end

    if screen == "main" then
        if action == "go_settings" then screen = "settings"; drawCurrent(); return end
        if action:sub(1, 7) == "toggle_" then
            local id = action:sub(8)
            toggleFarm(id)
            drawCurrent()
            return
        end

    elseif screen == "settings" then
        if action == "back" then screen = "main"; drawCurrent(); return end
        if action == "add_farm" then
            addDraft = {}; addBuf = ""; screen = "add_name"; drawCurrent(); return
        end
        if action == "set_ctrl"   then pickerTarget = "control"; screen = "pick_monitor"; drawCurrent(); return end
        if action == "set_stress" then pickerTarget = "stress";  screen = "pick_monitor"; drawCurrent(); return end
        if action == "set_anim"   then pickerTarget = "anim";    screen = "pick_monitor"; drawCurrent(); return end
        if action:sub(1, 4) == "del_" then
            local id = action:sub(5)
            for i, f in ipairs(config.farms) do
                if f.id == id then
                    f.enabled = false; applyFarm(f)
                    table.remove(config.farms, i)
                    break
                end
            end
            saveConfig()
            drawCurrent()
            return
        end

    elseif screen == "pick_monitor" then
        local function setForTarget(value)
            if pickerTarget == "control" then config.controlMonitor = value
            elseif pickerTarget == "stress" then config.stressMonitor = value
            elseif pickerTarget == "anim" then
                config.animMonitor = value
                matrixState = nil  -- reset animation
                -- If we cleared anim monitor, blank it
                if not value then
                    -- Cannot blank a screen we no longer reference; previous monitor will simply stop being updated
                end
            end
            saveConfig()
            -- Reset matrix state when anim changes
            if pickerTarget == "anim" then matrixState = nil end
        end

        if action == "pick_none" then
            setForTarget(nil)
            screen = "settings"; drawCurrent(); return
        end
        if action:sub(1, 5) == "pick_" then
            local idx = tonumber(action:sub(6))
            if idx then
                local mons = listByType("monitor")
                if mons[idx] then
                    setForTarget(mons[idx])
                    screen = "settings"; drawCurrent()
                end
            end
            return
        end

    elseif screen == "add_name" then
        if action:sub(1, 3) == "kb_" then
            local r, c = action:match("kb_(%d+)_(%d+)")
            r, c = tonumber(r), tonumber(c)
            local raw = KB_ROWS[r][c]
            local token = kbInsert(raw, kbShift)

            if token == "OK" then
                if #addBuf == 0 then return end
                addDraft.name = addBuf
                addBuf = ""
                kbShift = false
                screen = "add_relay"; drawCurrent()
            elseif token == "<" then
                if #addBuf > 0 then addBuf = addBuf:sub(1, -2); drawCurrent() end
            elseif token == "Sh" then
                kbShift = not kbShift
                drawCurrent()
            else
                if #addBuf < 24 then addBuf = addBuf .. token; drawCurrent() end
            end
            return
        end

    elseif screen == "add_relay" then
        if action:sub(1, 6) == "relay_" then
            local i = tonumber(action:sub(7))
            local relays = listByType("redstone_relay")
            if relays[i] then
                addDraft.relay = relays[i]
                screen = "add_side"; drawCurrent()
            end
            return
        end

    elseif screen == "add_side" then
        if action:sub(1, 5) == "side_" then
            local s = action:sub(6)
            addDraft.relaySide = s
            -- Save the new farm
            local farm = {
                id = genId(),
                name = addDraft.name,
                relay = addDraft.relay,
                relaySide = addDraft.relaySide,
                enabled = false,  -- Start disabled (relay HIGH = farm OFF in inverted logic)
            }
            table.insert(config.farms, farm)
            applyFarm(farm)
            saveConfig()
            addDraft = nil; addBuf = ""
            screen = "settings"; drawCurrent()
            return
        end
    end
end

-- ============================================ INITIAL MONITOR PICKER (CONSOLE) ============================================

local function pickMonitor()
    local mons = listByType("monitor")
    if #mons == 0 then
        print("No monitors detected.")
        print("Connect at least one monitor (control) and reboot.")
        while true do sleep(5) end
    end

    if #mons == 1 then
        config.controlMonitor = mons[1]
        saveConfig()
        return
    end

    print("=== STRESS CONTROL ===")
    print("Pick the CONTROL monitor (the touch UI).")
    print("Stress and anim monitors can be set later via Settings.")
    print("")
    for i, n in ipairs(mons) do print("  " .. i .. ". " .. n) end
    while true do
        write("Select 1-" .. #mons .. ": ")
        local line = read()
        local n = tonumber(line)
        if n and mons[n] then
            config.controlMonitor = mons[n]
            saveConfig()
            return
        end
    end
end

-- ============================================ MAIN LOOP ============================================

local function showConsoleSummary()
    term.setBackgroundColor(colors.black); term.clear(); term.setCursorPos(1, 1)
    term.setTextColor(colors.cyan); print("=== STRESS CONTROL v1.1 ===")
    term.setTextColor(colors.white)
    print("Control: " .. (config.controlMonitor or "?"))
    print("Stress:  " .. (config.stressMonitor or "(none)"))
    print("Anim:    " .. (config.animMonitor or "(none)"))
    print("Farms:   " .. #config.farms)
    if stressData and stressData.capacity > 0 then
        local pct = math.floor(stressData.current / stressData.capacity * 100 + 0.5)
        term.setTextColor(colors.lightGray)
        print(("SU:      %d/%d (%d%%)"):format(
            math.floor(stressData.current),
            math.floor(stressData.capacity), pct))
    elseif stressData then
        term.setTextColor(colors.yellow)
        print(("SU:      %d (network idle)"):format(math.floor(stressData.current)))
    else
        term.setTextColor(colors.gray)
        print("SU:      (no stressometer)")
    end
    if #config.farms > 0 then
        print("")
        for _, f in ipairs(config.farms) do
            local st = f.enabled and "ON" or "OFF"
            term.setTextColor(f.enabled and colors.lime or colors.gray)
            print(("  [%s] %s (%s/%s)"):format(st, f.name, f.relay, f.relaySide))
        end
    end
    term.setTextColor(colors.gray); print("")
    print("[R] reboot   [W] wipe state")
end

local function consoleLoop()
    showConsoleSummary()
    while true do
        local ev = { os.pullEvent() }
        if ev[1] == "key" then
            local k = ev[2]
            if k == keys.r then os.reboot()
            elseif k == keys.w then
                term.setTextColor(colors.red); print("Type YES to wipe:")
                if read() == "YES" then
                    fs.delete("farms.dat")
                    print("Wiped. Rebooting..."); sleep(1); os.reboot()
                else
                    showConsoleSummary()
                end
            end
        elseif ev[1] == "term_resize" then
            showConsoleSummary()
        end
    end
end

local function monitorLoop()
    readStress()
    drawCurrent()
    drawStressMonitor()
    drawAnimMonitor()

    local stressTimer = os.startTimer(1)
    local animTimer   = os.startTimer(0.2)  -- 5 fps

    while true do
        local ev = { os.pullEvent() }
        if ev[1] == "monitor_touch" then
            local n, x, y = ev[2], ev[3], ev[4]
            if n == config.controlMonitor then
                local action = findClicked(x, y)
                if action then handleAction(action) end
            end
            -- Touches on stress/anim monitors are ignored

        elseif ev[1] == "timer" then
            if ev[2] == stressTimer then
                local prev = stressData
                readStress()
                -- Always redraw stress monitor (changes anyway)
                drawStressMonitor()
                stressTimer = os.startTimer(1)
            elseif ev[2] == animTimer then
                drawAnimMonitor()
                animTimer = os.startTimer(0.2)
            end

        elseif ev[1] == "peripheral" then
            -- A peripheral attached: re-resolve stress and redraw all
            readStress()
            drawCurrent()
            drawStressMonitor()
            drawAnimMonitor()

        elseif ev[1] == "peripheral_detach" then
            local n = ev[2]
            if stressData and n == stressData.name then
                stressData = nil
                drawStressMonitor()
            end
            if n == config.animMonitor then
                matrixState = nil
            end

        elseif ev[1] == "monitor_resize" then
            local n = ev[2]
            if n == config.controlMonitor then drawCurrent()
            elseif n == config.stressMonitor then drawStressMonitor()
            elseif n == config.animMonitor then matrixState = nil; drawAnimMonitor() end
        end
    end
end

-- ============================================ STARTUP ============================================

loadConfig()

if not config.controlMonitor or not peripheral.wrap(config.controlMonitor) then
    pickMonitor()
end

-- Apply current state to all relays so reboot doesn't leave farms in random state.
applyAllFarms()

parallel.waitForAny(monitorLoop, consoleLoop)
