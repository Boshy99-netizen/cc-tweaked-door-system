-- Wrap drawing functions so buffer flushes automatically after each call.
-- This eliminates flicker: all writes happen on invisible window, then
-- single setVisible(true) blits the whole frame to the physical monitor.
do
    local _drawCurrent = drawCurrent
    local _drawStress  = drawStressMonitor
    local _drawVaults  = drawVaultsMonitor
    drawCurrent = function()
        _drawCurrent()
        flushAllMonitors()
    end
    drawStressMonitor = function()
        _drawStress()
        flushAllMonitors()
    end
    drawVaultsMonitor = function()
        _drawVaults()
        flushAllMonitors()
    end
end

-- ============================================ TOUCH HANDLING ============================================

local function findClicked(x, y)
    if not layoutCache then return nil end
    for action, r in pairs(layoutCache) do
        if x >= r.x1 and x <= r.x2 and y >= r.y1 and y <= r.y2 then return action end
    end
    return nil
end

local function handleAction(action)
    -- Universal cancel
    if action == "cancel" then
        if screen == "pick_monitor" then
            pickerTarget = nil
            screen = "settings"
        elseif screen == "add_vault_name" or screen == "add_vault_peri" then
            addDraft = nil; addBuf = ""; kbShift = false
            screen = "vaults"
        else
            addDraft = nil; addBuf = ""; kbShift = false
            screen = "settings"
        end
        drawCurrent()
        return
    end

    if screen == "main" then
        if action == "go_settings" then screen = "settings"; drawCurrent(); return end
        if action:sub(1, 7) == "toggle_" then
            local id = action:sub(8)
            toggleFarm(id)
            drawCurrent()
            return
        end

    elseif screen == "settings" then
        if action == "back" then screen = "main"; drawCurrent(); return end
        if action == "add_farm" then
            addDraft = {}; addBuf = ""; screen = "add_name"; drawCurrent(); return
        end
        if action == "set_ctrl"   then pickerTarget = "control"; screen = "pick_monitor"; drawCurrent(); return end
        if action == "set_stress" then pickerTarget = "stress";  screen = "pick_monitor"; drawCurrent(); return end
        if action == "set_anim"   then pickerTarget = "anim";    screen = "pick_monitor"; drawCurrent(); return end
        if action == "go_vaults"  then screen = "vaults"; drawCurrent(); return end
        if action:sub(1, 4) == "del_" then
            local id = action:sub(5)
            for i, f in ipairs(config.farms) do
                if f.id == id then
                    f.enabled = false; applyFarm(f)
                    table.remove(config.farms, i)
                    break
                end
            end
            saveConfig()
            drawCurrent()
            return
        end

    elseif screen == "pick_monitor" then
        local function setForTarget(value)
            if pickerTarget == "control" then config.controlMonitor = value
            elseif pickerTarget == "stress" then config.stressMonitor = value
            elseif pickerTarget == "anim" then config.animMonitor = value
            end
            saveConfig()
            -- Force redraw of all 3 monitors after change
            drawCurrent()
            drawStressMonitor()
            drawVaultsMonitor()
        end

        if action == "pick_none" then
            setForTarget(nil)
            screen = "settings"; drawCurrent(); return
        end
        if action:sub(1, 5) == "pick_" then
            local idx = tonumber(action:sub(6))
            if idx then
                local mons = listByType("monitor")
                if mons[idx] then
                    setForTarget(mons[idx])
                    screen = "settings"; drawCurrent()
                end
            end
            return
        end

    elseif screen == "add_name" then
        if action:sub(1, 3) == "kb_" then
            local r, c = action:match("kb_(%d+)_(%d+)")
            r, c = tonumber(r), tonumber(c)
            local raw = KB_ROWS[r][c]
            local token = kbInsert(raw, kbShift)

            if token == "OK" then
                if #addBuf == 0 then return end
                addDraft.name = addBuf
                addBuf = ""
                kbShift = false
                screen = "add_relay"; drawCurrent()
            elseif token == "<" then
                if #addBuf > 0 then addBuf = addBuf:sub(1, -2); drawCurrent() end
            elseif token == "Sh" then
                kbShift = not kbShift
                drawCurrent()
            else
                if #addBuf < 24 then addBuf = addBuf .. token; drawCurrent() end
            end
            return
        end

    elseif screen == "add_relay" then
        if action:sub(1, 6) == "relay_" then
            local i = tonumber(action:sub(7))
            local relays = listByType("redstone_relay")
            if relays[i] then
                addDraft.relay = relays[i]
                screen = "add_side"; drawCurrent()
            end
            return
        end

    elseif screen == "add_side" then
        if action:sub(1, 5) == "side_" then
            local s = action:sub(6)
            addDraft.relaySide = s
            -- Save the new farm
            local farm = {
                id = genId(),
                name = addDraft.name,
                relay = addDraft.relay,
                relaySide = addDraft.relaySide,
                enabled = false,  -- Start disabled (relay HIGH = farm OFF in inverted logic)
            }
            table.insert(config.farms, farm)
            applyFarm(farm)
            saveConfig()
            addDraft = nil; addBuf = ""
            screen = "settings"; drawCurrent()
            return
        end

    elseif screen == "vaults" then
        if action == "back" then screen = "settings"; drawCurrent(); return end
        if action == "add_vault" then
            addDraft = {}; addBuf = ""; kbShift = false
            screen = "add_vault_name"; drawCurrent(); return
        end
        if action:sub(1, 5) == "delv_" then
            local id = action:sub(6)
            for i, v in ipairs(config.vaults) do
                if v.id == id then table.remove(config.vaults, i); break end
            end
            vaultData[id] = nil
            saveConfig()
            drawCurrent()
            drawVaultsMonitor()
            return
        end

    elseif screen == "add_vault_name" then
        if action:sub(1, 3) == "kb_" then
            local r, c = action:match("kb_(%d+)_(%d+)")
            r, c = tonumber(r), tonumber(c)
            local raw = KB_ROWS[r][c]
            local token = kbInsert(raw, kbShift)
            if token == "OK" then
                if #addBuf == 0 then return end
                addDraft.name = addBuf
                addBuf = ""
                kbShift = false
                screen = "add_vault_peri"; drawCurrent()
            elseif token == "<" then
                if #addBuf > 0 then addBuf = addBuf:sub(1, -2); drawCurrent() end
            elseif token == "Sh" then
                kbShift = not kbShift; drawCurrent()
            else
                if #addBuf < 24 then addBuf = addBuf .. token; drawCurrent() end
            end
            return
        end

    elseif screen == "add_vault_peri" then
        if action:sub(1, 6) == "vperi_" then
            local i = tonumber(action:sub(7))
            local invs = listInventoryPeripherals()
            if invs[i] then
                local vault = {
                    id = genVaultId(),
                    name = addDraft.name,
                    peripheral = invs[i],
                }
                table.insert(config.vaults, vault)
                saveConfig()
                -- Placeholder until background poller reads it on next cycle
                vaultData[vault.id] = {
                    valid = false, pct = 0, slotsUsed = 0,
                    slotsTotal = 0, name = vault.name
                }
                addDraft = nil; addBuf = ""
                screen = "vaults"; drawCurrent()
                drawVaultsMonitor()
            end
            return
        end
    end
end

