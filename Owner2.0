-- ============================================
-- OWNER TABLET v12.0
-- Full base management: doors CRUD, ACL, pads, hardware setup.
-- ============================================

local KEY_CHANNEL    = 100
local REPLY_CHANNEL  = 101
local PING_INTERVAL  = 1
local RTT_INTERVAL   = 2
local LOCK_TIMEOUT   = 120  -- seconds of inactivity before auto-lock

-- ============================================ PIN HASH ============================================
-- Simple obfuscation hash (djb2 + salt + slow rounds). Not crypto-grade,
-- just so PIN doesn't sit as plaintext in .settings.

local function hashPin(pin, salt)
    salt = salt or tostring(os.getComputerID())
    local h = 5381
    local s = salt .. "|" .. pin .. "|" .. salt
    for i = 1, #s do
        h = ((h * 33) + string.byte(s, i)) % 0x100000000
    end
    -- Slow down brute force a tiny bit
    for _ = 1, 1000 do
        h = ((h * 33) + (h % 257)) % 0x100000000
    end
    return string.format("%08x", h)
end

-- ============================================ INIT ============================================

local playerName = settings.get("key_owner")
if not playerName then
    term.clear(); term.setCursorPos(1, 1)
    print("Enter your Minecraft name:")
    playerName = read()
    settings.set("key_owner", playerName); settings.save()
end

-- ============================================ MODEM (auto-recovery) ============================================

local modem, modemName = nil, nil

local function resolveModem()
    modem = peripheral.find("modem")
    if modem then
        modemName = peripheral.getName(modem)
        pcall(modem.open, REPLY_CHANNEL)
    else modemName = nil end
end

local function safeTransmit(payload)
    if not modem then resolveModem() end
    if not modem then return false end
    local ok = pcall(modem.transmit, KEY_CHANNEL, REPLY_CHANNEL, payload)
    if not ok then
        modem, modemName = nil, nil
        resolveModem()
        if modem then pcall(modem.transmit, KEY_CHANNEL, REPLY_CHANNEL, payload) end
    end
    return ok
end

resolveModem()
if not modem then
    term.clear(); term.setCursorPos(1, 1)
    print("ERROR: No wireless modem!")
    return
end

-- ============================================ STATE ============================================

local screen = "home"  -- home, doors, door_detail, door_users, door_user_edit, door_pwds, door_pwd_input, hardware, server, picker, input
local stack  = {}      -- screen stack for back navigation; entries: {screen, ctx}
local ctx    = {}      -- per-screen context (e.g. selected doorId, edit field)
local buttons = {}     -- action -> {x1,y1,x2,y2}

-- Lock screen state
local lockState     = "checking"  -- "first_setup", "confirm_setup", "locked", "unlocked"
local pinBuffer     = ""
local pinFirstEntry = ""
local pinError      = ""
local lastActivity  = os.clock()

local function isLocked()  return lockState ~= "unlocked" end
local function markActive() lastActivity = os.clock() end

-- Base info
local baseLocked, baseOwner = nil, nil
local baseTps, baseGameTime, baseGameDay = nil, nil, nil
local baseDoorsSummary = {}     -- light list for HOME/DOORS
local baseDoorsFull = {}        -- detailed list with users/pwds (when on detail screens)
local periList = { relays = {}, modems = {}, monitors = {}, statusMonitor = nil }

-- Round-trip ping
local pingNonce, pingPending, lastPingMs = 0, {}, nil

-- Command tracking (reliable delivery)
local cmdNonce, cmdPending = 0, {}
local cmdStatus, cmdMessage, cmdShownUntil = nil, nil, 0

-- Modal/input state
local inputBuf = ""
local inputCfg = nil  -- {title, prompt, onSubmit, allowChars, max, hidden}

-- Generic option picker
local pickerCfg = nil  -- {title, options=[{label,value}], onPick}

-- ============================================ TERM HELPERS ============================================

local function setBg(c) term.setBackgroundColor(c) end
local function setFg(c) term.setTextColor(c) end
local function clearScreen() setBg(colors.black); term.clear(); term.setCursorPos(1,1) end

local function drawFrame()
    local w, h = term.getSize()
    setBg(colors.black); setFg(colors.gray)
    term.setCursorPos(1, 1); term.write("+")
    term.setCursorPos(w, 1); term.write("+")
    term.setCursorPos(1, h); term.write("+")
    term.setCursorPos(w, h); term.write("+")
    for x = 2, w - 1 do
        term.setCursorPos(x, 1); term.write("=")
        term.setCursorPos(x, h); term.write("=")
    end
    for y = 2, h - 1 do
        term.setCursorPos(1, y); term.write("|")
        term.setCursorPos(w, y); term.write("|")
    end
end

local function drawHeader(title, color)
    color = color or colors.gray
    local w = term.getSize()
    setBg(color); setFg(colors.white)
    for x = 2, w - 1 do term.setCursorPos(x, 2); term.write(" ") end
    term.setCursorPos(math.floor((w - #title) / 2) + 1, 2)
    term.write(title)
    setBg(colors.black)
end

local function centerWrite(y, text, color)
    local w = term.getSize()
    if color then setFg(color) end
    term.setCursorPos(math.floor((w - #text) / 2) + 1, y)
    term.write(text)
end

local function drawBtn(x, y, text, bg, fg, action)
    setBg(bg); setFg(fg)
    term.setCursorPos(x, y); term.write(text)
    setBg(colors.black)
    if action then
        buttons[action] = { x1 = x, y1 = y, x2 = x + #text - 1, y2 = y }
    end
end

local function drawBackBtn(action)
    action = action or "back"
    local _, h = term.getSize()
    drawBtn(2, h - 1, "[< BACK]", colors.gray, colors.white, action)
end

local function trunc(s, n)
    s = tostring(s or "")
    if #s <= n then return s end
    return s:sub(1, n - 1) .. "."
end

-- ============================================ NETWORK ============================================

local function setCmdStatus(status, message)
    cmdStatus, cmdMessage = status, message
    if status == "sending" then cmdShownUntil = os.epoch("utc") + 30000
    else cmdShownUntil = os.epoch("utc") + 3000 end
end

local function sendCommand(cmd, data, label)
    cmdNonce = cmdNonce + 1
    local n = cmdNonce
    local payload = {
        type = "OWNER_COMMAND", nonce = n,
        player = playerName, command = cmd, data = data,
    }
    cmdPending[n] = { payload = payload, sentAt = os.epoch("utc"), retries = 0, label = label or cmd }
    safeTransmit(payload)
    setCmdStatus("sending", label or cmd)
end

local function sendKeyPing()
    safeTransmit({ type = "KEY_PING", keyType = "owner", player = playerName, timestamp = os.time() })
end

local function sendPingRequest()
    pingNonce = pingNonce + 1
    local n = pingNonce
    pingPending[n] = os.epoch("utc")
    safeTransmit({ type = "PING_REQUEST", nonce = n, player = playerName })
    local now = os.epoch("utc")
    for k, v in pairs(pingPending) do if now - v > 5000 then pingPending[k] = nil end end
end

local function requestDoors()
    safeTransmit({ type = "REQUEST_DOORS", player = playerName })
end

local function requestPeripherals()
    safeTransmit({ type = "REQUEST_PERIPHERALS", player = playerName })
end

-- ============================================ NAV ============================================

local drawCurrent  -- forward decl

local function pushScreen(s, c)
    table.insert(stack, { screen = screen, ctx = ctx })
    screen = s
    ctx = c or {}
    if s == "doors" or s == "door_detail" or s == "door_users" or s == "door_pwds" then
        requestDoors()
    end
    if s == "hardware" or s == "doors" or s == "door_detail" then
        requestPeripherals()
    end
    drawCurrent()
end

local function popScreen()
    local prev = table.remove(stack)
    if prev then screen, ctx = prev.screen, prev.ctx
    else screen, ctx = "home", {} end
    drawCurrent()
end

-- ============================================ NAVIGATION BAR ============================================

local function drawNavBar()
    local w, h = term.getSize()
    setBg(colors.black); setFg(colors.gray)
    term.setCursorPos(1, h - 2); term.write("+")
    for x = 2, w - 1 do term.setCursorPos(x, h - 2); term.write("-") end
    term.setCursorPos(w, h - 2); term.write("+")

    local tabs = {
        { key = "home",     label = "HOME",  act = "nav_home" },
        { key = "doors",    label = "DOORS", act = "nav_doors" },
        { key = "hardware", label = "HW",    act = "nav_hw" },
        { key = "server",   label = "SRV",   act = "nav_server" },
    }
    -- "doors" tab also highlights when on door_detail/users/pwds/door_user_edit/door_pwd_input
    local activeKey = screen
    if screen == "door_detail" or screen == "door_users" or screen == "door_pwds"
        or screen == "door_user_edit" or screen == "door_pwd_input" then
        activeKey = "doors"
    end

    local totalW = w - 2
    local tabW = math.floor(totalW / #tabs)
    local extra = totalW - tabW * #tabs
    local x = 2
    for i, t in ipairs(tabs) do
        local tw = tabW + (i == 1 and extra or 0)
        local active = (activeKey == t.key)
        local bg = active and colors.yellow or colors.gray
        local fg = active and colors.black or colors.white
        local pad = tw - #t.label
        local lp = math.floor(pad / 2); local rp = pad - lp
        local s = string.rep(" ", lp) .. t.label .. string.rep(" ", rp)
        if #s > tw then s = s:sub(1, tw) end
        setBg(bg); setFg(fg)
        term.setCursorPos(x, h - 1); term.write(s)
        buttons[t.act] = { x1 = x, y1 = h - 1, x2 = x + tw - 1, y2 = h - 1 }
        x = x + tw
    end
    setBg(colors.black)
end

local function drawCmdStatus(y)
    if not cmdStatus then return end
    local w = term.getSize()
    local txt, color
    if cmdStatus == "sending" then txt = "... " .. (cmdMessage or ""); color = colors.yellow
    elseif cmdStatus == "ok" then txt = "OK: " .. (cmdMessage or ""); color = colors.lime
    else txt = "FAIL: " .. (cmdMessage or "?"); color = colors.red end
    if #txt > w - 4 then txt = txt:sub(1, w - 4) end
    centerWrite(y, txt, color)
end

-- ============================================ HOME ============================================

local function drawHome()
    clearScreen(); drawFrame(); drawHeader(" ELECTRONIC PASS ")
    buttons = {}
    local w, h = term.getSize()

    setFg(colors.yellow)
    centerWrite(4, "  /\\  ")
    centerWrite(5, " /  \\ ")
    centerWrite(6, "<    >")
    centerWrite(7, " \\  / ")
    centerWrite(8, "  \\/  ")

    centerWrite(10, playerName, colors.white)
    centerWrite(11, "[OWNER]", colors.lime)

    -- Owner-on-base check
    if baseOwner ~= nil and baseOwner == "" then
        centerWrite(13, "Base unclaimed!", colors.yellow)
        local btn = "[ CLAIM THIS BASE ]"
        drawBtn(math.floor((w - #btn) / 2) + 1, 15, btn, colors.lime, colors.black, "claim_owner")
    elseif baseOwner ~= nil and not (string.lower(baseOwner) == string.lower(playerName)) then
        centerWrite(13, "Owner: " .. baseOwner, colors.red)
        centerWrite(14, "(not you)", colors.gray)
    else
        setFg(colors.gray); term.setCursorPos(3, 13); term.write("Base: ")
        if baseLocked == nil then setFg(colors.gray); term.write("...")
        elseif baseLocked then setFg(colors.red); term.write("LOCKED")
        else setFg(colors.lime); term.write("OPEN") end

        local txt = baseLocked and "[ UNLOCK BASE ]" or "[  LOCK BASE  ]"
        local bg  = baseLocked and colors.red or colors.purple
        drawBtn(math.floor((w - #txt) / 2) + 1, 15, txt, bg, colors.white, "toggle_lock")
        drawCmdStatus(16)
    end

    drawNavBar()
end

-- ============================================ DOORS LIST ============================================

local function drawDoors()
    clearScreen(); drawFrame(); drawHeader(" DOORS ")
    buttons = {}
    local w, h = term.getSize()
    local y = 4
    if #baseDoorsSummary == 0 then
        centerWrite(6, "(no doors yet)", colors.gray)
        centerWrite(7, "Tap [+ ADD] below.", colors.lightGray)
    else
        for _, d in ipairs(baseDoorsSummary) do
            if y >= h - 5 then break end
            local nm = trunc(d.name, w - 14)
            setFg(colors.white)
            term.setCursorPos(2, y); term.write(nm)
            local statusTxt = d.open and "OPEN" or "CLOSE"
            local color = d.open and colors.lime or colors.red
            if not d.enabled then statusTxt = "OFF"; color = colors.gray end
            setFg(color)
            term.setCursorPos(w - 13, y); term.write(statusTxt)
            drawBtn(w - 7, y, "[EDIT]", colors.blue, colors.white, "edit_" .. d.id)
            y = y + 1
        end
    end

    drawBtn(2, h - 4, " [+ ADD DOOR] ", colors.green, colors.white, "add_door")
    drawCmdStatus(h - 3)
    drawNavBar()
end

-- Find full door by id
local function findFullDoor(id)
    for _, d in ipairs(baseDoorsFull) do
        if d.id == id then return d end
    end
    return nil
end

-- ============================================ DOOR DETAIL ============================================

local SIDES = { "top", "bottom", "left", "right", "front", "back" }

local function drawDoorDetail()
    clearScreen(); drawFrame()
    local id = ctx.doorId
    local d = findFullDoor(id)
    if not d then drawHeader(" DOOR ... ") else drawHeader(" " .. trunc(d.name, 18) .. " ") end
    buttons = {}
    local w, h = term.getSize()

    if not d then
        centerWrite(6, "Loading door info...", colors.gray)
        drawNavBar(); drawBackBtn("back")
        return
    end

    local function row(y, label, val, action, valColor)
        setFg(colors.lightGray); term.setCursorPos(2, y); term.write(label)
        setFg(valColor or colors.white)
        local sx = 9
        local maxLen = w - sx - 8
        local s = trunc(val, maxLen)
        term.setCursorPos(sx, y); term.write(s)
        if action then
            drawBtn(w - 7, y, "[EDIT]", colors.blue, colors.white, action)
        end
    end

    row(4,  "Name:",   d.name,                                          "edit_name")
    row(5,  "Relay:",  d.relay ~= "" and d.relay or "(none)",           "edit_relay")
    row(6,  "Side:",   d.relaySide,                                     "edit_side")
    row(7,  "Modem:",  d.modem ~= "" and d.modem or "(none)",           "edit_modem")
    row(8,  "Radius:", tostring(d.radius),                              "edit_radius")
    row(9,  "InvRly:", d.normallyOn and "yes" or "no",                  "edit_invert")
    row(10, "Enabled:",d.enabled and "yes" or "no",                     "edit_enabled")
    row(11, "Pad:",    d.padMonitor and d.padMonitor or "(none)",       "edit_pad")
    row(12, "Users:",  tostring(#(d.users or {})), nil)
    drawBtn(w - 7, 12, "[OPEN]", colors.gray, colors.white, "go_users")
    row(13, "Pwds:",   tostring(d.passwordCount or 0), nil)
    drawBtn(w - 7, 13, "[OPEN]", colors.gray, colors.white, "go_pwds")

    -- Open/close right from detail
    if d.open then
        drawBtn(2, h - 5, " [CLOSE] ", colors.red, colors.white, "door_close")
    else
        drawBtn(2, h - 5, " [OPEN]  ", colors.green, colors.white, "door_open")
    end
    drawBtn(12, h - 5, " [DELETE] ", colors.red, colors.white, "delete_door")

    drawCmdStatus(h - 4)
    drawBackBtn("back")
    drawNavBar()
end

-- ============================================ USERS LIST ============================================

local function drawDoorUsers()
    clearScreen(); drawFrame()
    local id = ctx.doorId
    local d = findFullDoor(id)
    drawHeader(" " .. (d and trunc(d.name, 14) or "...") .. " - USERS ")
    buttons = {}
    local w, h = term.getSize()

    if not d then
        centerWrite(6, "Loading...", colors.gray)
        drawBackBtn("back"); drawNavBar(); return
    end

    local y = 4
    if not d.users or #d.users == 0 then
        centerWrite(6, "(no users)", colors.gray)
    else
        for _, u in ipairs(d.users) do
            if y >= h - 5 then break end
            setFg(colors.white)
            term.setCursorPos(2, y); term.write(trunc(u.name, w - 16))
            local lvlColor = u.level == "team" and colors.yellow or colors.lightBlue
            local lvlTxt   = u.level == "team" and "TEAM"        or "GUEST"
            setFg(lvlColor)
            term.setCursorPos(w - 13, y); term.write(lvlTxt)
            drawBtn(w - 7, y, "[DEL]", colors.red, colors.white, "del_user_" .. u.name)
            y = y + 1
        end
    end

    drawBtn(2, h - 4, " [+ ADD USER] ", colors.green, colors.white, "add_user")
    drawCmdStatus(h - 3)
    drawBackBtn("back")
    drawNavBar()
end

-- ============================================ PASSWORDS LIST ============================================

local function drawDoorPwds()
    clearScreen(); drawFrame()
    local id = ctx.doorId
    local d = findFullDoor(id)
    drawHeader(" " .. (d and trunc(d.name, 14) or "...") .. " - PASSWORDS ")
    buttons = {}
    local w, h = term.getSize()

    if not d then
        centerWrite(6, "Loading...", colors.gray)
        drawBackBtn("back"); drawNavBar(); return
    end

    local pwds = d.passwords or {}
    local y = 4
    if #pwds == 0 then
        centerWrite(6, "(no passwords)", colors.gray)
    else
        for i, pw in ipairs(pwds) do
            if y >= h - 5 then break end
            setFg(colors.white)
            term.setCursorPos(2, y); term.write("#" .. i .. ": ")
            setFg(colors.yellow); term.write(pw)
            drawBtn(w - 7, y, "[DEL]", colors.red, colors.white, "del_pwd_" .. pw)
            y = y + 1
        end
    end

    drawBtn(2, h - 4, " [+ ADD PWD] ", colors.green, colors.white, "add_pwd")
    drawCmdStatus(h - 3)
    drawBackBtn("back")
    drawNavBar()
end

