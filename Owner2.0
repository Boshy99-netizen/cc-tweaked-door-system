-- ============================================ SERVER ============================================

local function tpsColor(t)
    if t == nil then return colors.gray end
    if t >= 19 then return colors.lime end
    if t >= 15 then return colors.yellow end
    if t >= 10 then return colors.orange end
    return colors.red
end

local function pingColor(ms)
    if ms == nil then return colors.gray end
    if ms <= 80    then return colors.lime end
    if ms <= 250   then return colors.yellow end
    if ms <= 600   then return colors.orange end
    return colors.red
end

local function drawBar(x, y, width, value, vmax, color)
    local filled = math.floor((width * value) / vmax + 0.5)
    if filled < 0 then filled = 0 end
    if filled > width then filled = width end
    term.setCursorPos(x, y)
    setBg(color); term.write(string.rep(" ", filled))
    setBg(colors.gray); term.write(string.rep(" ", width - filled))
    setBg(colors.black)
end

local function fmtGameTime(t)
    if not t then return "--:--" end
    local hh = math.floor(t)
    local mm = math.floor((t - hh) * 60)
    return string.format("%02d:%02d", hh, mm)
end

local function isDay(t) if not t then return nil end; return t >= 6.0 and t < 18.0 end

local function drawServer()
    clearScreen(); drawFrame(); drawHeader(" SERVER ")
    buttons = {}
    local w, h = term.getSize()

    setFg(colors.gray); term.setCursorPos(3, 4); term.write("TPS")
    local tpsStr = baseTps and string.format("%.1f", baseTps) or "--"
    setFg(tpsColor(baseTps))
    term.setCursorPos(w - 1 - #tpsStr, 4); term.write(tpsStr)
    drawBar(3, 5, w - 4, baseTps or 0, 20, tpsColor(baseTps))

    setFg(colors.gray); term.setCursorPos(3, 7); term.write("PING")
    local pStr = lastPingMs and (tostring(lastPingMs) .. " ms") or "--"
    setFg(pingColor(lastPingMs))
    term.setCursorPos(w - 1 - #pStr, 7); term.write(pStr)
    drawBar(3, 8, w - 4, lastPingMs and math.min(600, lastPingMs) or 0, 600, pingColor(lastPingMs))

    setFg(colors.gray)
    for x = 3, w - 2 do term.setCursorPos(x, 10); term.write(".") end

    setFg(colors.gray); term.setCursorPos(3, 11); term.write("Day")
    if baseGameDay then
        setFg(colors.white); local s = tostring(baseGameDay)
        term.setCursorPos(w - 1 - #s, 11); term.write(s)
    end
    setFg(colors.gray); term.setCursorPos(3, 12); term.write("Time")
    setFg(colors.white)
    local ts = fmtGameTime(baseGameTime)
    term.setCursorPos(w - 1 - #ts, 12); term.write(ts)

    local d = isDay(baseGameTime)
    if d == true then setFg(colors.yellow); term.setCursorPos(3, 13); term.write("(*)  DAYTIME    ")
    elseif d == false then setFg(colors.lightBlue); term.setCursorPos(3, 13); term.write("(C)  NIGHTTIME  ")
    else setFg(colors.gray); term.setCursorPos(3, 13); term.write("...  unknown    ") end

    setFg(colors.gray); term.setCursorPos(3, 15); term.write("Real")
    setFg(colors.lightGray)
    local rt = textutils.formatTime(os.time("local"), true)
    term.setCursorPos(w - 1 - #rt, 15); term.write(rt)

    drawNavBar()
end

-- ============================================ MODALS: INPUT BOX & PICKER ============================================

local function drawInputModal()
    if not inputCfg then return end
    local w, h = term.getSize()
    local x1, x2 = 3, w - 2
    local y1, y2 = 6, 14
    setBg(colors.black)
    for y = y1, y2 do for x = x1, x2 do term.setCursorPos(x, y); term.write(" ") end end
    setFg(colors.gray)
    for x = x1, x2 do term.setCursorPos(x, y1); term.write("-"); term.setCursorPos(x, y2); term.write("-") end
    for y = y1, y2 do term.setCursorPos(x1, y); term.write("|"); term.setCursorPos(x2, y); term.write("|") end
    term.setCursorPos(x1, y1); term.write("+"); term.setCursorPos(x2, y1); term.write("+")
    term.setCursorPos(x1, y2); term.write("+"); term.setCursorPos(x2, y2); term.write("+")

    centerWrite(y1 + 2, inputCfg.title or "Input", colors.white)
    centerWrite(y1 + 3, inputCfg.prompt or "", colors.lightGray)

    local shown = inputCfg.hidden and string.rep("*", #inputBuf) or inputBuf
    local maxLen = w - 8
    if #shown > maxLen then shown = "..." .. shown:sub(-(maxLen - 3)) end
    setFg(colors.yellow)
    term.setCursorPos(x1 + 2, y1 + 5); term.write("> " .. shown .. "_")
    centerWrite(y2 - 1, "Enter=ok  Esc=cancel", colors.gray)
end

local function startInput(cfg)
    inputCfg = cfg
    inputBuf = cfg.initial or ""
    drawInputModal()
end

local function endInput(submit)
    if submit and inputCfg and inputCfg.onSubmit then
        inputCfg.onSubmit(inputBuf)
    end
    inputCfg = nil
    inputBuf = ""
    drawCurrent()  -- redraw underlying screen
end

local function drawPickerModal()
    if not pickerCfg then return end
    local w, h = term.getSize()
    local x1, x2 = 3, w - 2
    local y1, y2 = 4, h - 3
    setBg(colors.black)
    for y = y1, y2 do for x = x1, x2 do term.setCursorPos(x, y); term.write(" ") end end
    setFg(colors.gray)
    for x = x1, x2 do term.setCursorPos(x, y1); term.write("-"); term.setCursorPos(x, y2); term.write("-") end
    for y = y1, y2 do term.setCursorPos(x1, y); term.write("|"); term.setCursorPos(x2, y); term.write("|") end
    term.setCursorPos(x1, y1); term.write("+"); term.setCursorPos(x2, y1); term.write("+")
    term.setCursorPos(x1, y2); term.write("+"); term.setCursorPos(x2, y2); term.write("+")

    centerWrite(y1 + 1, pickerCfg.title or "Select", colors.white)

    buttons = {}  -- replace; only picker buttons matter while modal up
    local visStart = pickerCfg.scroll or 0
    local maxVis = y2 - y1 - 4
    local opts = pickerCfg.options or {}
    for i = 1, math.min(maxVis, #opts - visStart) do
        local idx = i + visStart
        local opt = opts[idx]
        local label = trunc(opt.label, w - 8)
        drawBtn(x1 + 2, y1 + 1 + i, " " .. label .. string.rep(" ", math.max(1, w - 7 - #label)) .. " ",
                colors.gray, colors.white, "pick_" .. idx)
    end
    -- Scroll buttons if needed
    if visStart > 0 then drawBtn(x2 - 4, y1 + 1, "[^]", colors.gray, colors.white, "pick_up") end
    if visStart + maxVis < #opts then drawBtn(x2 - 4, y2 - 1, "[v]", colors.gray, colors.white, "pick_dn") end
    drawBtn(x1 + 2, y2 - 1, "[CANCEL]", colors.red, colors.white, "pick_cancel")
end

local function startPicker(cfg)
    pickerCfg = cfg
    pickerCfg.scroll = 0
    drawPickerModal()
end

local function endPicker(value)
    local cb = pickerCfg and pickerCfg.onPick
    pickerCfg = nil
    if cb then cb(value) end
    drawCurrent()
end

-- ============================================ PIN SCREEN ============================================

local PIN_KEYS = {
    {"1","2","3"},
    {"4","5","6"},
    {"7","8","9"},
    {"<","0","OK"},  -- < = backspace, OK = submit
}

local function drawPinScreen()
    clearScreen(); drawFrame()
    buttons = {}

    local headerColor, headerText
    if lockState == "first_setup" then
        headerColor, headerText = colors.green, " SET PIN "
    elseif lockState == "confirm_setup" then
        headerColor, headerText = colors.green, " CONFIRM PIN "
    else
        headerColor, headerText = colors.red, " LOCKED "
    end
    drawHeader(headerText, headerColor)

    local w, h = term.getSize()

    -- Title text
    if lockState == "first_setup" then
        centerWrite(4, "Set 4-digit PIN", colors.white)
        centerWrite(5, "for your tablet", colors.lightGray)
    elseif lockState == "confirm_setup" then
        centerWrite(4, "Re-enter PIN", colors.white)
        centerWrite(5, "to confirm", colors.lightGray)
    else
        centerWrite(4, playerName, colors.white)
        centerWrite(5, "Enter PIN", colors.lightGray)
    end

    -- PIN dots (4 positions)
    local dotsY = 7
    local startX = math.floor(w / 2) - 3
    for i = 1, 4 do
        term.setCursorPos(startX + (i - 1) * 2, dotsY)
        if i <= #pinBuffer then
            term.setTextColor(colors.yellow); term.write("*")
        else
            term.setTextColor(colors.gray); term.write("_")
        end
    end

    -- Error message
    if pinError ~= "" then
        centerWrite(8, pinError, colors.red)
    end

    -- Numpad keys
    local btnW, btnH = 6, 2
    local gridW = btnW * 3 + 2
    local kpStartX = math.floor((w - gridW) / 2) + 1
    local kpStartY = h - (btnH * 4 + 3) - 1
    if kpStartY < 10 then kpStartY = 10 end

    for r = 1, 4 do
        for c = 1, 3 do
            local ch = PIN_KEYS[r][c]
            local x  = kpStartX + (c - 1) * (btnW + 1)
            local y  = kpStartY + (r - 1) * (btnH + 1)
            local bg, fg = colors.lightGray, colors.black
            if ch == "OK" then bg, fg = colors.green, colors.white
            elseif ch == "<" then bg, fg = colors.red, colors.white end
            -- Fill rect
            for yy = y, y + btnH - 1 do
                term.setCursorPos(x, yy)
                term.setBackgroundColor(bg)
                term.write(string.rep(" ", btnW))
            end
            -- Centered text
            local cx = x + math.floor((btnW - #ch) / 2)
            local cy = y + math.floor(btnH / 2)
            term.setCursorPos(cx, cy)
            term.setTextColor(fg); term.setBackgroundColor(bg)
            term.write(ch)

            buttons["pin_" .. ch] = { x1 = x, y1 = y, x2 = x + btnW - 1, y2 = y + btnH - 1 }
        end
    end
    term.setBackgroundColor(colors.black)
end

-- handle one PIN keypress: digit char ("0".."9"), "<", or "OK"
local function handlePinInput(key)
    markActive()
    pinError = ""

    if key == "<" then
        if #pinBuffer > 0 then pinBuffer = pinBuffer:sub(1, -2) end
        drawPinScreen(); return
    end

    if key == "OK" then
        if #pinBuffer ~= 4 then
            pinError = "PIN must be 4 digits"
            drawPinScreen(); return
        end

        if lockState == "first_setup" then
            pinFirstEntry = pinBuffer
            pinBuffer = ""
            lockState = "confirm_setup"
            drawPinScreen()
        elseif lockState == "confirm_setup" then
            if pinBuffer == pinFirstEntry then
                local hash = hashPin(pinBuffer)
                settings.set("pin_hash", hash); settings.save()
                pinBuffer = ""; pinFirstEntry = ""
                lockState = "unlocked"
                markActive()
                drawCurrent()
            else
                pinError = "PINs do not match"
                pinBuffer = ""; pinFirstEntry = ""
                lockState = "first_setup"
                drawPinScreen()
            end
        elseif lockState == "locked" then
            local saved = settings.get("pin_hash") or ""
            if saved == hashPin(pinBuffer) then
                pinBuffer = ""
                lockState = "unlocked"
                markActive()
                drawCurrent()
            else
                pinError = "Wrong PIN"
                pinBuffer = ""
                drawPinScreen()
                sleep(0.5)  -- mild brute-force slowdown
            end
        end
        return
    end

    -- digit
    if #pinBuffer < 4 then
        pinBuffer = pinBuffer .. key
        drawPinScreen()
    end
end

-- ============================================ DRAW DISPATCHER ============================================

drawCurrent = function()
    if isLocked() then drawPinScreen(); return end

    if screen == "home" then drawHome()
    elseif screen == "doors" then drawDoors()
    elseif screen == "door_detail" then drawDoorDetail()
    elseif screen == "door_users" then drawDoorUsers()
    elseif screen == "door_pwds" then drawDoorPwds()
    elseif screen == "hardware" then drawHardware()
    elseif screen == "server" then drawServer()
    end
    if inputCfg then drawInputModal() end
    if pickerCfg then drawPickerModal() end
end

-- ============================================ ACTION HANDLERS ============================================

local function navTab(key)
    -- Drop the stack so going back from a tab doesn't reopen modal subscreens
    stack = {}
    if key == "home" then screen = "home"
    elseif key == "doors" then screen = "doors"; requestDoors(); requestPeripherals()
    elseif key == "hardware" then screen = "hardware"; requestPeripherals()
    elseif key == "server" then screen = "server"; sendPingRequest()
    end
    ctx = {}
    drawCurrent()
end

-- Helpers for door-add flow
local pendingAddDoor = {}

local function pickRelay(onPick)
    local opts = {}
    for _, n in ipairs(periList.relays) do table.insert(opts, { label = n, value = n }) end
    if #opts == 0 then setCmdStatus("fail", "no relays found"); drawCurrent(); return end
    startPicker({ title = "Pick relay", options = opts, onPick = onPick })
end

local function pickModem(onPick)
    local opts = {}
    for _, n in ipairs(periList.modems) do table.insert(opts, { label = n, value = n }) end
    if #opts == 0 then setCmdStatus("fail", "no modems found"); drawCurrent(); return end
    startPicker({ title = "Pick modem", options = opts, onPick = onPick })
end

local function pickMonitor(allowNone, onPick)
    local opts = {}
    if allowNone then table.insert(opts, { label = "(none)", value = "" }) end
    for _, n in ipairs(periList.monitors) do table.insert(opts, { label = n, value = n }) end
    if #opts == 0 then setCmdStatus("fail", "no monitors found"); drawCurrent(); return end
    startPicker({ title = "Pick monitor", options = opts, onPick = onPick })
end

local function pickSide(onPick)
    local opts = {}
    for _, s in ipairs(SIDES) do table.insert(opts, { label = s, value = s }) end
    startPicker({ title = "Relay side", options = opts, onPick = onPick })
end

local function startAddDoor()
    pendingAddDoor = {}
    -- Step 1: name
    startInput({
        title = "New door", prompt = "Name:", initial = "Door",
        onSubmit = function(name)
            if name == "" then return end
            pendingAddDoor.name = name
            -- Step 2: relay
            pickRelay(function(relay)
                if not relay then return end
                pendingAddDoor.relay = relay
                pickSide(function(side)
                    if not side then return end
                    pendingAddDoor.relaySide = side
                    pickModem(function(modem)
                        if not modem then return end
                        pendingAddDoor.modem = modem
                        startInput({
                            title = "Radius", prompt = "Range in blocks", initial = "5",
                            onSubmit = function(r)
                                pendingAddDoor.radius = tonumber(r) or 5
                                startPicker({
                                    title = "Inverted relay?",
                                    options = { { label = "no  (normal)", value = false },
                                                { label = "yes (inverted)", value = true } },
                                    onPick = function(inv)
                                        if inv == nil then return end
                                        pendingAddDoor.normallyOn = inv
                                        sendCommand("door_add", pendingAddDoor, "add door")
                                    end,
                                })
                            end,
                        })
                    end)
                end)
            end)
        end,
    })
end

local function handleAction(action)
    -- Tab navigation always available
    if action == "nav_home"   then navTab("home"); return end
    if action == "nav_doors"  then navTab("doors"); return end
    if action == "nav_hw"     then navTab("hardware"); return end
    if action == "nav_server" then navTab("server"); return end
    if action == "back"       then popScreen(); return end

    -- Picker scroll/cancel (handled inside picker modal generically)
    if pickerCfg then
        if action == "pick_up" then
            pickerCfg.scroll = math.max(0, (pickerCfg.scroll or 0) - 1)
            drawPickerModal(); return
        elseif action == "pick_dn" then
            pickerCfg.scroll = (pickerCfg.scroll or 0) + 1
            drawPickerModal(); return
        elseif action == "pick_cancel" then
            endPicker(nil); return
        elseif action:sub(1, 5) == "pick_" then
            local idx = tonumber(action:sub(6))
            if idx and pickerCfg.options[idx] then
                endPicker(pickerCfg.options[idx].value); return
            end
            return
        end
    end

    -- HOME
    if action == "claim_owner" then sendCommand("claim_owner", nil, "claim"); return end
    if action == "toggle_lock" then
        sendCommand("toggle_lock", nil, baseLocked and "unlock" or "lock")
        if baseLocked == nil then baseLocked = false end
        baseLocked = not baseLocked
        drawCurrent(); return
    end

    -- DOORS list
    if action == "add_door" then startAddDoor(); return end
    if action:sub(1, 5) == "edit_" and screen == "doors" then
        local id = action:sub(6); pushScreen("door_detail", { doorId = id }); return
    end

    -- DOOR DETAIL
    if screen == "door_detail" then
        local id = ctx.doorId
        local d = findFullDoor(id)
        if action == "door_open"  then sendCommand("door_open",  { id = id }, "open"); return end
        if action == "door_close" then sendCommand("door_close", { id = id }, "close"); return end
        if action == "delete_door" then
            startPicker({
                title = "Delete door?",
                options = { { label = "Yes, delete", value = true }, { label = "Cancel", value = false } },
                onPick = function(v)
                    if v then
                        sendCommand("door_remove", { id = id }, "delete")
                        sleep(0.3); popScreen()
                    end
                end,
            })
            return
        end
        if action == "edit_name" then
            startInput({ title = "Rename", prompt = "Door name:", initial = d and d.name or "",
                onSubmit = function(v) if v ~= "" then sendCommand("door_update", { id = id, name = v }, "rename") end end })
            return
        end
        if action == "edit_relay" then
            pickRelay(function(v) if v then sendCommand("door_update", { id = id, relay = v }, "set relay") end end)
            return
        end
        if action == "edit_side" then
            pickSide(function(v) if v then sendCommand("door_update", { id = id, relaySide = v }, "set side") end end)
            return
        end
        if action == "edit_modem" then
            pickModem(function(v) if v then sendCommand("door_update", { id = id, modem = v }, "set modem") end end)
            return
        end
        if action == "edit_radius" then
            startInput({ title = "Radius", prompt = "Blocks:", initial = d and tostring(d.radius) or "5",
                onSubmit = function(v) local n = tonumber(v); if n then sendCommand("door_update", { id = id, radius = n }, "set radius") end end })
            return
        end
        if action == "edit_invert" then
            sendCommand("door_update", { id = id, normallyOn = not (d and d.normallyOn) }, "toggle inv")
            return
        end
        if action == "edit_enabled" then
            sendCommand("door_update", { id = id, enabled = not (d and d.enabled) }, "toggle ena")
            return
        end
        if action == "edit_pad" then
            pickMonitor(true, function(v) if v ~= nil then sendCommand("door_set_pad", { id = id, monitor = v }, "set pad") end end)
            return
        end
        if action == "go_users" then pushScreen("door_users", { doorId = id }); return end
        if action == "go_pwds"  then pushScreen("door_pwds",  { doorId = id }); return end
    end

    -- USERS
    if screen == "door_users" then
        if action == "add_user" then
            startInput({ title = "Add user", prompt = "Player name:",
                onSubmit = function(name)
                    if name == "" then return end
                    startPicker({
                        title = "Access level for " .. name,
                        options = { { label = "GUEST (denied when LOCKED)", value = "guest" },
                                    { label = "TEAM  (always allowed)",     value = "team"  } },
                        onPick = function(lvl)
                            if lvl then sendCommand("door_user_set", { id = ctx.doorId, user = name, level = lvl }, "add user") end
                        end,
                    })
                end })
            return
        end
        if action:sub(1, 9) == "del_user_" then
            local nm = action:sub(10)
            sendCommand("door_user_set", { id = ctx.doorId, user = nm, level = nil }, "del user")
            return
        end
    end

    -- PWDS
    if screen == "door_pwds" then
        if action == "add_pwd" then
            startInput({ title = "Add password", prompt = "Digits/letters:", hidden = false,
                onSubmit = function(p) if p ~= "" then sendCommand("door_pwd_add", { id = ctx.doorId, password = p }, "add pwd") end end })
            return
        end
        if action:sub(1, 8) == "del_pwd_" then
            local pw = action:sub(9)
            sendCommand("door_pwd_remove", { id = ctx.doorId, password = pw }, "del pwd")
            return
        end
    end

    -- HARDWARE
    if screen == "hardware" then
        if action == "edit_status_mon" then
            pickMonitor(true, function(v) if v ~= nil then sendCommand("set_status_monitor", { monitor = v }, "set status mon") end end)
            return
        end
        if action == "refresh_peri" then requestPeripherals(); setCmdStatus("ok", "refreshed"); drawCurrent(); return end
        if action == "set_owner" then
            startInput({ title = "Set owner", prompt = "New owner name:", initial = baseOwner or "",
                onSubmit = function(v) if v ~= "" then sendCommand("set_owner", { name = v }, "set owner") end end })
            return
        end
        if action == "change_pin" then
            -- Reset pin and re-enter setup mode
            settings.unset("pin_hash"); settings.save()
            lockState = "first_setup"
            pinBuffer = ""
            pinFirstEntry = ""
            pinError = ""
            drawPinScreen()
            return
        end
        if action == "lock_now" then
            lockState = "locked"
            pinBuffer = ""
            pinError = ""
            drawPinScreen()
            return
        end
        if action == "set_base_pin" then
            startInput({
                title = "Set base wipe PIN",
                prompt = "4 digits (empty = clear):",
                max = 4,
                onSubmit = function(v)
                    if v == "" then
                        sendCommand("set_base_pin", { pinHash = "" }, "clear base pin")
                    elseif #v == 4 and v:match("^%d%d%d%d$") then
                        local hash = hashPin(v, "base")
                        sendCommand("set_base_pin", { pinHash = hash }, "set base pin")
                    else
                        setCmdStatus("fail", "need 4 digits")
                        drawCurrent()
                    end
                end,
            })
            return
        end
    end
end

-- ============================================ KEYBOARD INPUT ============================================

local function handleKey(key)
    if not inputCfg then return end
    if key == keys.enter then endInput(true); return end
    if key == keys.escape then endInput(false); return end
    if key == keys.backspace then
        if #inputBuf > 0 then inputBuf = inputBuf:sub(1, -2); drawInputModal() end
        return
    end
end

local function handleChar(ch)
    if not inputCfg or not ch or #ch == 0 then return end
    local maxLen = inputCfg.max or 32
    if #inputBuf >= maxLen then return end
    local b = string.byte(ch)
    if b >= 32 and b <= 126 then
        inputBuf = inputBuf .. ch
        drawInputModal()
    end
end

-- ============================================ MAIN LOOP ============================================

local function findClickedAction(x, y)
    for name, area in pairs(buttons) do
        if x >= area.x1 and x <= area.x2 and y >= area.y1 and y <= area.y2 then
            return name
        end
    end
    return nil
end

local function mainLoop()
    clearScreen()
    print("=== OWNER TABLET v12 ===")
    print("Player: " .. playerName)
    sleep(0.3)

    -- Decide initial lock state
    local savedHash = settings.get("pin_hash")
    if savedHash and savedHash ~= "" then
        lockState = "locked"
    else
        lockState = "first_setup"
        pinBuffer = ""
        pinFirstEntry = ""
    end

    drawCurrent()
    sendKeyPing(); sendPingRequest()
    requestPeripherals()

    local pingT = os.startTimer(PING_INTERVAL)
    local rttT  = os.startTimer(RTT_INTERVAL)
    local refrT = os.startTimer(0.5)

    while true do
        local event = { os.pullEventRaw() }
        local ev = event[1]

        if ev == "timer" then
            local id = event[2]
            if id == pingT then sendKeyPing(); pingT = os.startTimer(PING_INTERVAL)
            elseif id == rttT then sendPingRequest(); rttT = os.startTimer(RTT_INTERVAL)
            elseif id == refrT then
                -- Auto-lock after inactivity
                if lockState == "unlocked" and (os.clock() - lastActivity) > LOCK_TIMEOUT then
                    lockState = "locked"
                    pinBuffer = ""
                    pinError = ""
                    drawPinScreen()
                end
                -- Retry pending commands without ACK after 0.7s, max 3 retries
                local now = os.epoch("utc")
                for n, p in pairs(cmdPending) do
                    local age = now - p.sentAt
                    if age > 700 then
                        if p.retries >= 3 then
                            cmdPending[n] = nil
                            setCmdStatus("fail", "no answer")
                        else
                            p.retries = p.retries + 1
                            p.sentAt = now
                            safeTransmit(p.payload)
                        end
                    end
                end
                if cmdShownUntil > 0 and now > cmdShownUntil and cmdStatus ~= "sending" then
                    cmdStatus, cmdMessage = nil, nil
                end
                if not isLocked() and (screen == "server" or screen == "home") then
                    drawCurrent()
                end
                refrT = os.startTimer(0.5)
            end

        elseif ev == "modem_message" then
            local message = event[5]
            if type(message) == "table" then
                local mt = message.type
                if mt == "BASE_STATUS" then
                    baseLocked = message.locked
                    baseOwner  = message.owner or ""
                    baseTps    = message.tps or baseTps
                    baseGameTime = message.gameTime or baseGameTime
                    baseGameDay  = message.gameDay or baseGameDay
                    baseDoorsSummary = message.doors or {}
                    if not isLocked() then drawCurrent() end
                elseif mt == "DOORS_FULL" then
                    baseDoorsFull = message.doors or {}
                    if not isLocked() and (screen == "doors" or screen == "door_detail" or screen == "door_users" or screen == "door_pwds") then
                        drawCurrent()
                    end
                elseif mt == "PERIPHERAL_LIST" then
                    periList = {
                        relays   = message.relays   or {},
                        modems   = message.modems   or {},
                        monitors = message.monitors or {},
                        statusMonitor = message.statusMonitor,
                    }
                    if not isLocked() and screen == "hardware" then drawCurrent() end
                elseif mt == "PING_REPLY" then
                    local n = message.nonce
                    local sent = pingPending[n]
                    if sent then lastPingMs = os.epoch("utc") - sent; pingPending[n] = nil end
                    if message.tps then baseTps = message.tps end
                    if message.gameTime then baseGameTime = message.gameTime end
                    if message.gameDay then baseGameDay = message.gameDay end
                    if not isLocked() and screen == "server" then drawCurrent() end
                elseif mt == "OWNER_ACK" then
                    local n = message.nonce
                    local p = cmdPending[n]
                    if p then
                        cmdPending[n] = nil
                        if message.success then
                            setCmdStatus("ok", p.label)
                            requestDoors()
                        else
                            setCmdStatus("fail", message.reason or "rejected")
                        end
                        if not isLocked() then drawCurrent() end
                    end
                end
            end

        elseif ev == "mouse_click" or ev == "monitor_touch" then
            local x, y = event[3], event[4]
            if isLocked() then
                local clicked = findClickedAction(x, y)
                if clicked and clicked:sub(1, 4) == "pin_" then
                    handlePinInput(clicked:sub(5))
                end
            elseif inputCfg then
                local w, h = term.getSize()
                if x < 3 or x > w - 2 or y < 6 or y > 14 then
                    endInput(false)
                end
                -- swallow click either way; input box has no clickable controls
            else
                markActive()
                local clicked = findClickedAction(x, y)
                if clicked then handleAction(clicked) end
            end

        elseif ev == "key" then
            local k = event[2]
            if isLocked() then
                if k >= keys.zero and k <= keys.nine then
                    handlePinInput(string.char(k - keys.zero + string.byte("0")))
                elseif k >= keys.numPad0 and k <= keys.numPad9 then
                    handlePinInput(string.char(k - keys.numPad0 + string.byte("0")))
                elseif k == keys.backspace then
                    handlePinInput("<")
                elseif k == keys.enter or k == keys.numPadEnter then
                    handlePinInput("OK")
                end
            elseif inputCfg then
                markActive()
                handleKey(k)
            else
                markActive()
            end

        elseif ev == "char" then
            local ch = event[2]
            if not isLocked() and inputCfg then
                markActive()
                handleChar(ch)
            end

        elseif ev == "peripheral" then
            if event[2] then
                local ok, t = pcall(peripheral.getType, event[2])
                if ok and t == "modem" then resolveModem() end
            end
        elseif ev == "peripheral_detach" then
            if event[2] == modemName then modem, modemName = nil, nil; resolveModem() end
        end
    end
end

mainLoop()
